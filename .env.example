# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agent_hiring_board?schema=public"

# Hedera Testnet
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.XXXXX
HEDERA_OPERATOR_KEY=302e...

# LLM
GROQ_API_KEY=gsk_...

# Auto-populated after first agent registration
DISPATCHER_ACCOUNT_ID=
DISPATCHER_INBOUND_TOPIC_ID=
DISPATCHER_OUTBOUND_TOPIC_ID=
SUMMARIZER_ACCOUNT_ID=
SUMMARIZER_INBOUND_TOPIC_ID=
SUMMARIZER_OUTBOUND_TOPIC_ID=
CONTENT_GEN_ACCOUNT_ID=
CONTENT_GEN_INBOUND_TOPIC_ID=
CONTENT_GEN_OUTBOUND_TOPIC_ID=

# Connection topics (set after init)
DISPATCHER_SUMMARIZER_CONNECTION=
DISPATCHER_CONTENT_GEN_CONNECTION=

# HCS topics for on-chain logs
ESCROW_TOPIC_ID=
RECEIPT_TOPIC_ID=
REPUTATION_TOPIC_ID=
RATING_TOPIC_ID=

# API
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
