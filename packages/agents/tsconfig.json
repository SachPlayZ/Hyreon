{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "paths": {
      "@repo/shared": ["../shared/src/index.ts"],
      "@repo/database": ["../database/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
